# ──────────────────────────────────────────────────────────────────────────────
# CixioHub Notify Service — Environment Variables
#
# Copy this file to .env and fill in the values before running the service.
#   cp .env.example .env
#
# .env is listed in .gitignore and will never be committed.
# ──────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────
# Database (shared with hub_backend)
# ──────────────────────────────────────────
# asyncpg driver is required (postgresql+asyncpg://...)
DATABASE_URL=postgresql+asyncpg://cixiohub:cixiohub@localhost:5432/cixiohub

# ──────────────────────────────────────────
# RabbitMQ
# ──────────────────────────────────────────
# Used by queue/producer.py (bulk notify path) and queue/consumer.py.
# Default guest credentials work for a local Docker RabbitMQ instance.
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
MAX_RETRY_ATTEMPTS=4

# ──────────────────────────────────────────
# Email (SMTP)
# ──────────────────────────────────────────
# Local dev (Mailpit — catches all email without sending):
#   SMTP_HOST=localhost
#   SMTP_PORT=1025
#   SMTP_USERNAME=        (leave empty — Mailpit needs no auth)
#   SMTP_PASSWORD=        (leave empty)
#
# Production (Gmail App Password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=your@gmail.com
#   SMTP_PASSWORD=<16-char app password from Google Account → Security → App Passwords>
#
# TLS mode is derived from SMTP_PORT automatically:
#   1025 → no TLS   465 → SSL/TLS   587 → STARTTLS
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@cixiohub.dev

# ──────────────────────────────────────────
# Twilio (SMS + WhatsApp)
# ──────────────────────────────────────────
# Credentials are available at https://console.twilio.com (Account Info panel).
# Instructor will share test credentials for the internship.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=          # E.164 format, e.g. +14155552671 (SMS)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886   # Twilio sandbox default

# ──────────────────────────────────────────
# Firebase (FCM Push — Android + iOS via FlutterFire)
# ──────────────────────────────────────────
# How to generate:
#   1. Firebase Console → Project Settings → Service Accounts
#   2. "Generate new private key" → download JSON
#   3. Base64-encode it:
#        macOS/Linux : base64 -i service-account.json
#        Windows PS  : [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
#   4. Paste the single-line output below (no line breaks)
FIREBASE_SERVICE_ACCOUNT_JSON=

# ──────────────────────────────────────────
# AWS SNS (APNs Push — iOS direct path, optional)
# ──────────────────────────────────────────
# Only needed if sending iOS push via AWS SNS instead of Firebase.
# Leave empty to use the FCM path for both Android and iOS.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
SNS_PLATFORM_ARN_IOS=
